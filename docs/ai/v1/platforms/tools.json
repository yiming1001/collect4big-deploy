      "icon": "🎙️",
      "input_schema": {
        "show_collect_settings": true,
        "fields": [
          {
            "key": "file_url",
            "label": "音视频文件URL",
            "type": "input",
            "placeholder": "请输入可访问的公网URL（如：https://example.com/video.mp4）",
            "required": true
          }
        ]
      },
      "collection": {
        "endpoint_path": "/tools/asr/transcribe",
        "request_method": "POST",
        "request_payload_mode": "json",
        "params": [
          "file_url"
