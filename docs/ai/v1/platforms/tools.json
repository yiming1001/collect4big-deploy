        "string_params": [],
        "omit_empty_params": [],
        "request_meta": {},
        "response_meta": {},
        "data_path": "data",
        "pagination": null,
        "estimate_per_page": 1,
        "allow_collect_all": false,
        "param_operator": null,
        "extract_operator": null
