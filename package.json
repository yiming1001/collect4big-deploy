{
  "name": "vue-template",
  "version": "1.0.0",
  "output": "dist",
  "scripts": {
    "generate:ai-catalog": "node --experimental-default-type=module scripts/generate-ai-catalog.mjs",
    "dev": "vite",
    "build": "npm run generate:ai-catalog && vite build && rm -rf dist && cp -r docs dist",
    "test:ai-catalog": "node --experimental-default-type=module --test tests/ai-catalog.test.mjs",
    "test:skill": "node --test tests/collect4big-agent.test.cjs",
    "test": "npm run test:ai-catalog && npm run test:skill",
    "preview": "vite preview --port 4173"
  },
  "dependencies": {
    "@element-plus/icons-vue": "^2.3.2",
    "@lark-base-open/js-sdk": "^0.5.0",
    "element-plus": "^2.3.6",
    "reset-css": "^5.0.1",
    "vue": "^3.2.37",
    "vue-i18n": "^9.4.1",
    "vue-router": "^4.6.3"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^3.0.1",
    "unplugin-auto-import": "^0.16.4",
    "unplugin-vue-components": "^0.25.1",
    "vite": "^3.0.1"
  },
  "description": "这是项目的生产部署版本，包含编译后的静态文件。",
  "main": "vite.config.js",
  "directories": {
    "doc": "docs"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yiming1001/collect4big.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/yiming1001/collect4big/issues"
  },
  "homepage": "https://github.com/yiming1001/collect4big#readme"
}
